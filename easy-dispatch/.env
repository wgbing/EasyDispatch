# ===== EasyDispatch 环境变量示例 =====
# 复制为 .env 后修改：cp .env.example .env

# ---- 数据库 ----
POSTGRES_DB=easydispatch
POSTGRES_USER=easydispatch
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ---- 邮件配置 ----
# Mock 模式：true=仅打印日志不发送（默认）；false=走真实 SMTP
MAIL_MOCK=false

# ===== 163 邮箱配置示例（推荐 465 + SSL）=====
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false
MAIL_USERNAME=jeecglic@163.com
MAIL_PASSWORD=MCUNGTDJVJZYRYPQ
MAIL_FROM=jeecglic@163.com

# ===== 其他邮箱参考 =====
# QQ 邮箱：MAIL_HOST=smtp.qq.com  MAIL_PORT=465  MAIL_SSL_ENABLE=true
# Gmail：  MAIL_HOST=smtp.gmail.com  MAIL_PORT=587  MAIL_SSL_ENABLE=false  MAIL_STARTTLS_ENABLE=true
# 126 邮箱：MAIL_HOST=smtp.126.com  MAIL_PORT=465  MAIL_SSL_ENABLE=true

# ---- 日志级别 ----
LOG_LEVEL=INFO
